{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (NGO or Volunteer)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["ngo", "volunteer"] },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Volunteer skills" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "NGO report data and AI analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ngoId": { "type": "string" },
        "content": { "type": "string" },
        "analysis": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ngoId", "content", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "Individual task extracted from a report",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "ngoId": { "type": "string" },
        "volunteerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "urgency": { "type": "string", "enum": ["Immediate", "Soon", "Planned"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "in-progress", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reportId", "ngoId", "title", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "NGO reports and analysis"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Individual tasks extracted from reports"
    }
  }
}
