{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (NGO or Volunteer)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["ngo", "volunteer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Report": {
      "title": "Report",
      "description": "NGO report data and AI analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ngoId": { "type": "string" },
        "content": { "type": "string" },
        "analysis": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ngoId", "content", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "NGO reports and analysis"
    }
  }
}
