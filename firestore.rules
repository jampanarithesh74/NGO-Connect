rules_version = '2';
service cloud.firestore {
  // Explicitly target the database ID from the config
  match /databases/ai-studio-b9780aae-b3c1-46e9-9bb0-f19aa70b8c04/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNGO() {
      return isSignedIn() && 
             exists(/databases/ai-studio-b9780aae-b3c1-46e9-9bb0-f19aa70b8c04/documents/users/$(request.auth.uid)) &&
             get(/databases/ai-studio-b9780aae-b3c1-46e9-9bb0-f19aa70b8c04/documents/users/$(request.auth.uid)).data.role == 'ngo';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isSignedIn();
      // Allow NGOs to credit points to volunteers
      allow update: if isNGO() && 
                   incoming().diff(existing()).affectedKeys().hasAny(['impactPoints', 'totalPoints', 'earnedBadges', 'updatedAt']);
    }

    // Task Rules
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
    }

    // Report Rules
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isNGO(); 
      allow update: if isNGO();
      allow delete: if isNGO();
    }

    // Squad Rules
    match /squads/{squadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // Chat Rules
    match /squads/{squadId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Notification Rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
